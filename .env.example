# meridian — normalises screenpipe activity into structured app sessions
#
# Copy this file to ~/.meridian/.env and fill in your credentials.
# The daemon loads ~/.meridian/.env automatically at startup.
# Never commit the real .env — it contains secrets.

# ---------------------------------------------------------------------------
# Core (optional — defaults shown)
# ---------------------------------------------------------------------------

# SCREENPIPE_DB=~/.screenpipe/db.sqlite
# MERIDIAN_DB=~/.meridian/meridian.db
# POLL_INTERVAL_SECS=60
# RUST_LOG=meridian=info

# Classification backend: "hermes" (default) | "mlx"
#   hermes — dynamic local-LLM selector (LM Studio / Ollama / llama.cpp / mlx_lm),
#            cloud fallback configured in services/.hermes/.env.
#   mlx    — persistent MLX inference server (Apple Silicon). The daemon calls its
#            /classify_sessions endpoint. Install with ./install.sh --mlx.
# CLASSIFIER_BACKEND=mlx
# MLX_SERVER_HOST=127.0.0.1
# MLX_SERVER_PORT=7823

# Dashboard (Next.js UI) port. Defaults to 3939. Change this and re-run
# `meridian setup` to move the dashboard.
# MERIDIAN_UI_PORT=3939

# ---------------------------------------------------------------------------
# Jira (all three required to enable the Jira connector)
# ---------------------------------------------------------------------------

# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=you@your-org.com
# JIRA_API_TOKEN=your-api-token-here
# JIRA_PROJECT_KEYS=KAN,ENG          # optional — comma-separated; empty = all projects

# ---------------------------------------------------------------------------
# PM worklog (Stage 4) — automated Jira worklogs from classified sessions.
# Runs inside the Rust daemon: one hour-driven worklog per task per hour,
# synthesised via the MLX server's /synthesise_worklog endpoint, then posted
# to Jira over REST. Requires the MLX server (it hosts the synth agent).
# ---------------------------------------------------------------------------

# Master switch. Default false: the driver DRAFTS worklogs every hour but never
# POSTs to real Jira until you flip this on. Turn on only when ready to write.
# PM_WORKLOG_POST_ENABLED=false

# Driver cadence in hours (clamped to a 60s floor). Default 1.0.
# PM_WORKLOG_INTERVAL_HOURS=1.0

# Routing thresholds before a drafted worklog is eligible to post.
# PM_WORKLOG_MIN_CONFIDENCE=0.65
# PM_WORKLOG_MIN_COVERAGE=0.80

# A session still settling longer than this many minutes is treated as ready so
# one stuck row can't deadlock an hour (the readiness aging escape).
# PM_WORKLOG_READINESS_AGING_MIN=90

# Jira's hard floor — worklogs below this many real seconds are never posted.
# PM_WORKLOG_MIN_POST_SECONDS=60

# HTTP timeout for one synth call to the MLX server (the agno agent can take ~60s).
# PM_WORKLOG_SYNTH_TIMEOUT_S=300

# ---------------------------------------------------------------------------
# GitHub (both required to enable the GitHub connector)
# ---------------------------------------------------------------------------

# GITHUB_TOKEN=ghp_your_personal_access_token
# GITHUB_ORG=your-org
# GITHUB_REPOS=your-org/api,your-org/web  # optional — comma-separated; empty = all org repos

# ---------------------------------------------------------------------------
# Linear (required to enable the Linear connector)
# ---------------------------------------------------------------------------

# LINEAR_API_KEY=lin_api_your_key_here
# LINEAR_TEAM_IDS=TEAM1,TEAM2        # optional — comma-separated; empty = all teams

# ---------------------------------------------------------------------------
# Python LLM backend — only used by the hermes classifier (CLASSIFIER_BACKEND=hermes)
# and the MLX summariser fallback. The MLX classifier backend ignores these.
# ---------------------------------------------------------------------------

# Local-LLM discovery: 1 = try local servers first (LM Studio / Ollama / llama.cpp /
# mlx_lm), fall back to cloud; 0 = always use the cloud fallback below.
# LLM_PREFER_LOCAL=1
# Fraction of free Metal GPU memory the agent may use for its own mlx_lm.server.
# LLM_BUDGET_PCT=0.5

# Cloud LLM fallback (any OpenAI-compatible endpoint), used when no local server
# is found. Example values for OpenAI / OpenRouter / Anthropic-compat:
# OLLAMA_MODEL=claude-sonnet-4-6
# OLLAMA_HOST=https://api.anthropic.com/v1
# OLLAMA_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...      # used by the coding-agent summariser's Claude path

# Jira (Python side reads JIRA_URL; the Rust daemon reads JIRA_BASE_URL above —
# set both to the same value when Jira is configured).
# JIRA_URL=https://your-org.atlassian.net

# hermes embedded API server (optional, hermes backend only).
# API_SERVER_ENABLED=0
# API_SERVER_KEY=

# Disable Python OTLP tracing regardless of OO config (1 = off).
# MERIDIAN_TRACING_DISABLED=0

# Confident AI key for the classifier eval harness (services/tests/evals only).
# CONFIDENT_API_KEY=

# ---------------------------------------------------------------------------
# OpenObserve / OpenTelemetry (optional — enables distributed tracing and
# structured log ingestion into a local OpenObserve instance)
# ---------------------------------------------------------------------------

# base64(email:password) for your local OpenObserve instance.
# When unset, OTLP export is silently skipped — logs still go to .jsonl files.
# Generate: echo -n "you@your-org.com:yourpassword" | base64
# MERIDIAN_OO_AUTH=base64encodedcredentials

# OTLP/HTTP trace endpoint (Rust daemon)
# MERIDIAN_OTLP_ENDPOINT=http://localhost:5080/api/default/v1/traces

# OTLP/HTTP trace endpoint (Python services — same value, different var name)
# MERIDIAN_OTLP_TRACES_ENDPOINT=http://localhost:5080/api/default/v1/traces

# Log level for Python agents: DEBUG | INFO | WARNING | ERROR
# DEBUG dumps full session text, raw LLM prompts, and rule hit details.
# LOG_LEVEL=INFO
