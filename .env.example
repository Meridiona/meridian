# meridian — normalises screenpipe activity into structured app sessions
#
# Copy this file to ~/.meridian/.env and fill in your credentials.
# The daemon loads ~/.meridian/.env automatically at startup.
# Never commit the real .env — it contains secrets.

# ---------------------------------------------------------------------------
# Core (optional — defaults shown)
# ---------------------------------------------------------------------------

# SCREENPIPE_DB=~/.screenpipe/db.sqlite
# MERIDIAN_DB=~/.meridian/meridian.db
# POLL_INTERVAL_SECS=60
# RUST_LOG=meridian=info

# ---------------------------------------------------------------------------
# Jira (all three required to enable the Jira connector)
# ---------------------------------------------------------------------------

# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=you@your-org.com
# JIRA_API_TOKEN=your-api-token-here
# JIRA_PROJECT_KEYS=KAN,ENG          # optional — comma-separated; empty = all projects

# ---------------------------------------------------------------------------
# GitHub (both required to enable the GitHub connector)
# ---------------------------------------------------------------------------

# GITHUB_TOKEN=ghp_your_personal_access_token
# GITHUB_ORG=your-org
# GITHUB_REPOS=your-org/api,your-org/web  # optional — comma-separated; empty = all org repos

# ---------------------------------------------------------------------------
# Linear (required to enable the Linear connector)
# ---------------------------------------------------------------------------

# LINEAR_API_KEY=lin_api_your_key_here
# LINEAR_TEAM_IDS=TEAM1,TEAM2        # optional — comma-separated; empty = all teams
