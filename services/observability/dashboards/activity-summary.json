        {
          "id": "tbl",
          "type": "table",
          "title": "All activity_report runs \u2014 newest first",
          "description": "",
          "config": {
            "show_legends": false,
            "wrap_table_cells": false,
            "drilldown": [
              {
                "name": "Open trace",
                "type": "byUrl",
                "targetBlank": true,
                "findBy": "name",
                "data": {
                  "url": "/web/traces?org_identifier=default&stream=default&search_type=ui&search_mode=spans&period=30d&query=${row.field.trace_filter}",
                  "folder": "",
                  "dashboard": "",
                  "tab": "",
                  "passAllVariables": false,
                  "variables": []
                }
              }
            ]
          },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT\n  to_char(to_timestamp_micros(_timestamp + 19800000000),'%Y-%m-%d %H:%M') as \"Time (IST)\",\n  concat(substr(ar_label,1,10),' ',lpad(CAST((CAST(substr(ar_label,12,2) AS BIGINT)-6+24)%24 AS VARCHAR),2,'0'),':30 - ',lpad(CAST((CAST(substr(ar_label,12,2) AS BIGINT)-5+24)%24 AS VARCHAR),2,'0'),':30 UTC') as \"UTC range\",\n  concat(substr(ar_label,1,10),' ',substr(ar_label,12,2),':00 - ',lpad(CAST((CAST(substr(ar_label,12,2) AS BIGINT)+1)%24 AS VARCHAR),2,'0'),':00 IST') as \"IST range\",\n  ar_input_tokens as \"In tokens\",\n  ar_output_tokens as \"Out tokens\",\n  ar_think_tokens as \"Think tokens\",\n  round(CAST(ar_elapsed_s AS DOUBLE),1) as \"Elapsed (s)\",\n  trace_id,\n  encode(concat('trace_id=''', trace_id, ''''),'base64') as trace_filter\nFROM \"default\" WHERE service_name='meridian-mlx-server' AND body LIKE '%activity_report%' AND ar_input_tokens IS NOT NULL ORDER BY _timestamp DESC",
              "customQuery": true,
              "fields": {
                "stream": "default",
                "stream_type": "logs",
                "x": [
                  {
                    "label": "Time (IST)",
                    "alias": "Time (IST)",
                    "column": "Time (IST)",
                    "isDerived": false,
                    "havingConditions": []
                  },
                  {
                    "label": "UTC range",
                    "alias": "UTC range",
                    "column": "UTC range",
                    "isDerived": false,
                    "havingConditions": []
                  },
                  {
                    "label": "IST range",
                    "alias": "IST range",
                    "column": "IST range",
                    "isDerived": false,
                    "havingConditions": []
                  },
                  {
                    "label": "In tokens",
                    "alias": "In tokens",
                    "column": "In tokens",
                    "isDerived": false,
                    "havingConditions": []
                  },
                  {
                    "label": "Out tokens",
                    "alias": "Out tokens",
                    "column": "Out tokens",
                    "isDerived": false,
                    "havingConditions": []
                  },
                  {
                    "label": "Think tokens",
                    "alias": "Think tokens",
                    "column": "Think tokens",
                    "isDerived": false,
                    "havingConditions": []
                  },
                  {
                    "label": "Elapsed (s)",
                    "alias": "Elapsed (s)",
                    "column": "Elapsed (s)",
                    "isDerived": false,
                    "havingConditions": []
                  },
                  {
