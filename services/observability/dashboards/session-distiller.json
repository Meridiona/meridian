            {
              "query": "SELECT\n  to_char(to_timestamp_micros(_timestamp + 19800000000),'%Y-%m-%d %H:%M') as \"Time (IST)\",\n  distil_label as \"Hour\",\n  distil_nsess as \"Sessions\",\n  distil_input_tokens_est as \"In tokens\",\n  distil_output_tokens_est as \"Out tokens\",\n  concat(CAST(distil_reduction_pct AS VARCHAR),'%') as \"Reduction\",\n  distil_n_after_junk as \"After junk\",\n  distil_n_after_df as \"After df\",\n  distil_n_after_lex as \"After lex\",\n  distil_n_after_sem as \"After sem\",\n  distil_n_selected as \"Selected\",\n  distil_n_session_rescued as \"Rescued\",\n  distil_n_entity_rescued as \"Entity rescued\",\n  round(CAST(distil_elapsed_s AS DOUBLE),1) as \"Elapsed (s)\",\n  trace_id\nFROM \"default\" WHERE service_name='meridian-mlx-server' AND distil_label IS NOT NULL ORDER BY _timestamp DESC",
              "customQuery": true,
              "fields": {
