          "layout": { "x": 96, "y": 0, "w": 32, "h": 18, "i": 4 }
        },
        {
          "id": "m5",
          "type": "metric",
          "title": "Avg elapsed (s)",
          "description": "",
          "config": { "show_legends": false, "no_value_replacement": "0", "decimals": 1.0 },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT round(avg(wl_elapsed_s),1) as y FROM \"default\" WHERE service_name='meridian-mlx-server' AND wl_hour IS NOT NULL",
              "customQuery": true,
              "fields": {
                "stream": "default", "stream_type": "logs", "x": [],
                "y": [{ "label": "Avg elapsed (s)", "alias": "y", "column": "y", "color": "#9959b2", "isDerived": false, "havingConditions": [] }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
