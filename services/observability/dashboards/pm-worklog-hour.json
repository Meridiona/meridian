        },
        {
          "id": "m3",
          "type": "metric",
          "title": "Proposed new task",
          "description": "",
          "config": { "show_legends": false, "no_value_replacement": "0", "decimals": 0.0 },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT count(*) as y FROM \"default\" WHERE service_name='meridian-mlx-server' AND wl_hour IS NOT NULL AND wl_proposed = 1",
              "customQuery": true,
              "fields": {
                "stream": "default", "stream_type": "logs", "x": [],
                "y": [{ "label": "Proposed", "alias": "y", "column": "y", "color": "#b29959", "isDerived": false, "havingConditions": [] }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1.0 }
            }
          ],
          "layout": { "x": 64, "y": 0, "w": 32, "h": 18, "i": 3 }
        },
        {
          "id": "m4",
          "type": "metric",
          "title": "Avg sessions/hour",
          "description": "",
          "config": { "show_legends": false, "no_value_replacement": "0", "decimals": 0.0 },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT round(avg(wl_nsess),0) as y FROM \"default\" WHERE service_name='meridian-mlx-server' AND wl_hour IS NOT NULL",
              "customQuery": true,
              "fields": {
                "stream": "default", "stream_type": "logs", "x": [],
                "y": [{ "label": "Avg sessions", "alias": "y", "column": "y", "color": "#59a0b2", "isDerived": false, "havingConditions": [] }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1.0 }
