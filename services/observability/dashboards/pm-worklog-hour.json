{
  "version": 8,
  "title": "PM Worklog Hour",
  "description": "worklog_hour pipeline runs — one log record per processed hour (success AND error). Click a row → Open this trace to walk the whole hour: sessions → activity report → classify tiers → propose → worklog drafts, each with input/prompt/output. Fields: wl_hour, wl_nsess, wl_tier, wl_n_matched, wl_matched_keys, wl_proposed, wl_proposed_title, wl_proposed_type, wl_note, wl_error, wl_elapsed_s.",
  "tabs": [
    {
      "tabId": "default",
      "name": "Default",
      "panels": [
        {
          "id": "m1",
          "type": "metric",
          "title": "Total runs",
          "description": "",
          "config": { "show_legends": false, "no_value_replacement": "0", "decimals": 0.0 },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT count(*) as y FROM \"default\" WHERE service_name='meridian-mlx-server' AND wl_hour IS NOT NULL",
              "customQuery": true,
              "fields": {
                "stream": "default", "stream_type": "logs", "x": [],
                "y": [{ "label": "Total runs", "alias": "y", "column": "y", "color": "#5960b2", "isDerived": false, "havingConditions": [] }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1.0 }
            }
          ],
          "layout": { "x": 0, "y": 0, "w": 32, "h": 18, "i": 1 }
        },
        {
          "id": "m2",
          "type": "metric",
          "title": "Matched runs",
          "description": "",
          "config": { "show_legends": false, "no_value_replacement": "0", "decimals": 0.0 },
          "queryType": "sql",
          "queries": [
            {
              "query": "SELECT count(*) as y FROM \"default\" WHERE service_name='meridian-mlx-server' AND wl_hour IS NOT NULL AND wl_n_matched > 0",
              "customQuery": true,
              "fields": {
                "stream": "default", "stream_type": "logs", "x": [],
                "y": [{ "label": "Matched runs", "alias": "y", "column": "y", "color": "#59b27a", "isDerived": false, "havingConditions": [] }],
                "z": [], "breakdown": [], "filter": { "filterType": "group", "logicalOperator": "AND", "conditions": [] }
              },
              "config": { "promql_legend": "", "layer_type": "scatter", "weight_fixed": 1.0 }
