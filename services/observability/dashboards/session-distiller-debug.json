        {
          "id": "table_runs",
          "type": "table",
          "title": "Distillation runs (newest first)",
          "description": "One row per distil_hour / distil_range call. Filter by Distil label above. Click a row \u2192 opens the full trace waterfall (distil.embed + one distil.session child per session). Input/output token estimates use chars\u00f74.",
