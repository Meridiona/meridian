# meridian — hermes gateway secrets template
# Copy to services/.hermes/.env and fill in values.
# NEVER commit .hermes/.env — it is gitignored.

# ── Model provider ────────────────────────────────────────────────────────────
OLLAMA_API_KEY=your-ollama-cloud-key-here

# ── API server ────────────────────────────────────────────────────────────────
# Bearer token Rust uses to call the gateway. Pick any string.
API_SERVER_ENABLED=true
API_SERVER_KEY=meridian-local

# ── Optional overrides ────────────────────────────────────────────────────────
# API_SERVER_PORT=8642
# API_SERVER_HOST=127.0.0.1
# OLLAMA_MODEL=gemma4:31b        # override model
# OLLAMA_HOST=https://ollama.com/v1
