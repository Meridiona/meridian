# =============================================================================
# Activity Intelligence Agents — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values you need.

# ──────────────────────────────────────────────────────────────────────────────
# LLM provider (used by the Watcher, Synthesizer, and Jira Keeper agents)
# ──────────────────────────────────────────────────────────────────────────────
# Defaults target Ollama Cloud running nemotron-3-super.
# Override with any OpenAI-compatible endpoint (LM Studio, OpenAI, OpenRouter…).

# Ollama Cloud (default)
OLLAMA_API_KEY=
# HERMES_MODEL=nemotron-3-super
# HERMES_BASE_URL=https://ollama.com/v1

# Anthropic (uncomment to use)
# ANTHROPIC_API_KEY=
# HERMES_MODEL=claude-sonnet-4-6
# HERMES_BASE_URL=https://api.anthropic.com/v1

# OpenAI / OpenRouter (uncomment to use)
# OPENAI_API_KEY=
# HERMES_MODEL=gpt-4o
# HERMES_BASE_URL=https://api.openai.com/v1

# Local LM Studio (uncomment to use)
# HERMES_MODEL=local-model
# HERMES_BASE_URL=http://localhost:1234/v1

# ──────────────────────────────────────────────────────────────────────────────
# Jira (used by the Jira Keeper agent only — leave empty to skip Jira sync)
# ──────────────────────────────────────────────────────────────────────────────
# Atlassian Cloud URL, e.g. https://yourorg.atlassian.net
JIRA_URL=
# Email associated with the Atlassian account
JIRA_EMAIL=
# Atlassian API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=
