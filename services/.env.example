# =============================================================================
# Activity Intelligence Agents — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values you need.

# ──────────────────────────────────────────────────────────────────────────────
# Local LLM selection (Apple Silicon — auto-detected, no config required)
# ──────────────────────────────────────────────────────────────────────────────
# On Apple Silicon, the agent automatically detects any running LLM server
# (LM Studio on :1234, Ollama on :11434, llama.cpp / mlx_lm on :8080/:8765)
# and uses the first loaded model.  No env vars needed for the happy path.
#
# LLM_PREFER_LOCAL=1   — try local first, fall back to cloud if none found (default)
# LLM_PREFER_LOCAL=0   — skip local discovery, always use the cloud fallback below
LLM_PREFER_LOCAL=1

# Fraction of free Metal GPU memory the agent may use when it starts its own
# mlx_lm.server (0.5 = 50%).  Has no effect when LM Studio / Ollama is already
# running — those servers manage their own memory.
LLM_BUDGET_PCT=0.5

# ──────────────────────────────────────────────────────────────────────────────
# Cloud LLM fallback (used when no local server is found, and by jira_updater)
# ──────────────────────────────────────────────────────────────────────────────
# These three vars are the cloud fallback for task classification and the
# primary LLM config for the Jira updater (which has no local selection).
# Set them to any OpenAI-compatible endpoint.

# OpenAI
# OLLAMA_MODEL=gpt-4o
# OLLAMA_HOST=https://api.openai.com/v1
# OLLAMA_API_KEY=sk-...

# OpenRouter
# OLLAMA_MODEL=anthropic/claude-sonnet-4-6
# OLLAMA_HOST=https://openrouter.ai/api/v1
# OLLAMA_API_KEY=sk-or-...

# Anthropic (via OpenAI-compat proxy)
# OLLAMA_MODEL=claude-sonnet-4-6
# OLLAMA_HOST=https://api.anthropic.com/v1
# OLLAMA_API_KEY=sk-ant-...

# ──────────────────────────────────────────────────────────────────────────────
# Observability (OpenObserve OTLP exporter)
# ──────────────────────────────────────────────────────────────────────────────
# Base64-encoded "user:password" for the OpenObserve OTLP endpoint.
# Required by install-tagger-daemon.sh — launchd must inject this directly
# because observability.py initialises the exporter before dotenv is loaded.
# Generate with: echo -n "user@example.com:password" | base64
MERIDIAN_OO_AUTH=

# ──────────────────────────────────────────────────────────────────────────────
# Jira (used by the Jira Keeper agent only — leave empty to skip Jira sync)
# ──────────────────────────────────────────────────────────────────────────────
# Atlassian Cloud URL, e.g. https://yourorg.atlassian.net
JIRA_URL=
# Email associated with the Atlassian account
JIRA_EMAIL=
# Atlassian API token — generate at https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=
