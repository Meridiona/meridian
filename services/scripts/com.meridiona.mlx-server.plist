<?xml version="1.0" encoding="UTF-8"?>
<!--
    com.meridiona.mlx-server — persistent MLX inference server.

    Loads the Qwen3.5-2B model lazily on first request and serves the worklog
    pipeline endpoints to the Rust daemon. KeepAlive keeps it running across
    crashes; launchd restarts it automatically.

    Install:
        services/scripts/install-mlx-server-daemon.sh
    Uninstall:
        services/scripts/uninstall-mlx-server-daemon.sh
    Status / logs:
        launchctl print gui/$(id -u)/com.meridiona.mlx-server
        tail -f ~/.meridian/logs/mlx-server.log
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.meridiona.mlx-server</string>

    <key>WorkingDirectory</key>
    <string>{{REPO_ROOT}}/services</string>

    <!-- uv resolves the managed Python and activates the venv before exec.
         UV_PROJECT_ENVIRONMENT points to services/.venv (prepared by
         setup-services.sh for dev, or install-from-bundle.sh for npm installs).
         --no-sync skips lockfile resolution at daemon startup. -->
    <key>ProgramArguments</key>
    <array>
        <string>{{UV_BIN}}</string>
        <string>run</string>
        <string>--no-sync</string>
        <string>--project</string>
        <string>{{REPO_ROOT}}/services</string>
        <string>python</string>
        <string>-m</string>
        <string>agents.server</string>
        <string>--port</string>
        <string>{{MLX_SERVER_PORT}}</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HOME</key>
        <string>{{HOME}}</string>
        <!-- Pin the HuggingFace cache so the wizard's eager prefetch and the
             runtime's lazy model loads always resolve the SAME directory (this is
             the default location, made explicit so the two paths can't diverge). -->
        <key>HF_HOME</key>
        <string>{{HOME}}/.cache/huggingface</string>
        <!-- Rust-accelerated, parallel-chunk HF downloads (the hf_transfer dep).
             Must be set before the process imports huggingface_hub, so it lives
             here rather than in code. Faster + resilient to stalling shards. -->
        <key>HF_HUB_ENABLE_HF_TRANSFER</key>
        <string>1</string>
        <key>UV_PROJECT_ENVIRONMENT</key>
        <string>{{SERVICES_VENV}}</string>
        <key>MERIDIAN_DB</key>
        <string>{{HOME}}/.meridian/meridian.db</string>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
        <key>TQDM_MININTERVAL</key>
        <string>3</string>
        <key>MLX_SERVER_PORT</key>
        <string>{{MLX_SERVER_PORT}}</string>
        <key>MERIDIAN_OO_AUTH</key>
        <string>{{MERIDIAN_OO_AUTH}}</string>
        <key>MERIDIAN_OTLP_ENDPOINT</key>
        <string>{{MERIDIAN_OTLP_ENDPOINT}}</string>
    </dict>

    <key>StandardOutPath</key>
    <string>{{HOME}}/.meridian/logs/mlx-server.log</string>
    <key>StandardErrorPath</key>
    <string>{{HOME}}/.meridian/logs/mlx-server-error.log</string>

    <!-- Start immediately when loaded and after every crash. -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <!-- Wait 5 s before restarting after a crash (avoids tight crash loops). -->
    <key>ThrottleInterval</key>
    <integer>5</integer>
    <!-- ProcessType omitted — defaults to Standard QoS. -->
</dict>
</plist>
