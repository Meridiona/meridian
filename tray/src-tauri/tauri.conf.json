{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Meridian",
  "version": "0.1.0",
  "identifier": "com.meridiona.tray",
  "build": {
    "frontendDist": "../../ui/out",
    "devUrl": "http://localhost:3939",
    "beforeDevCommand": "cd ../ui && npm run dev",
    "beforeBuildCommand": "cd ../ui && npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Meridian",
        "url": "popover/index.html",
        "width": 384,
        "height": 490,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "shadow": true,
        "focus": false
      },
      {
        "label": "tray-tooltip",
        "title": "Meridian",
        "url": "popover/tooltip.html",
        "width": 288,
        "height": 180,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "shadow": false,
        "focus": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null
    },
    "resources": {
      "../../target/release/meridian": "backend/meridian",
      "../../scripts/a11y-helper/meridian-a11y-helper": "backend/meridian-a11y-helper",
      "../../scripts/com.meridiona.daemon.plist": "backend/com.meridiona.daemon.plist",
      "../../scripts/com.meridiona.a11y-helper.plist": "backend/com.meridiona.a11y-helper.plist"
    }
  }
}
