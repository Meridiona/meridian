{
  "name": "meridian-mcp",
  "version": "1.27.1",
  "description": "MCP server for Meridian \u2014 query app sessions, focus time, and activity data",
  "main": "dist/index.js",
  "bin": {
    "meridian-mcp": "dist/index.js",
    "meridian-mcp-install": "dist/install.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "install-mcp": "node dist/install.js",
    "dev": "ts-node src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "meridian",
    "model-context-protocol",
    "activity",
    "screenpipe",
    "ai"
  ],
  "author": "Meridiona",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@opentelemetry/api": "1.9",
    "@opentelemetry/exporter-trace-otlp-http": "0.55",
    "@opentelemetry/resources": "1.28",
    "@opentelemetry/sdk-node": "0.55",
    "@opentelemetry/semantic-conventions": "1.28",
    "pino": "9",
    "sql.js": "1.14.1"
  },
  "devDependencies": {
    "@types/node": "22.0.0",
    "@types/sql.js": "1.4.11",
    "ts-node": "10.9.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
