MERIDIAN_DB_PATH=~/.meridian/meridian.db
# base64(email:password) for OpenObserve — auth for UI trace export via OTLP
MERIDIAN_OO_AUTH=
# UI OTLP trace export is OFF by default. Opt in to send spans to OpenObserve:
# MERIDIAN_OTEL_ENABLED=1
# Quiet the UI logger (pino): trace|debug|info|warn|error|fatal (default: info)
# LOG_LEVEL=warn
