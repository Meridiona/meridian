#!/usr/bin/env bash
# meridian — normalises screenpipe activity into structured app sessions
set -e

echo ""
echo "=== pre-push checks ==="
echo ""

# ── 1. Rust format ──────────────────────────────────────────────────────────
echo "[1/5] cargo fmt check..."
export SQLX_OFFLINE=true
cargo fmt --check || { echo "ERROR: Run 'cargo fmt' before pushing."; exit 1; }

# ── 2. Rust lint ────────────────────────────────────────────────────────────
echo "[2/5] cargo clippy..."
cargo clippy -- -D warnings || { echo "ERROR: Fix clippy warnings before pushing."; exit 1; }

# ── 3. Rust tests ───────────────────────────────────────────────────────────
echo "[3/5] cargo test..."
cargo test || { echo "ERROR: Rust tests failed. Fix before pushing."; exit 1; }

# ── 4. UI build ─────────────────────────────────────────────────────────────
echo "[4/5] UI build (cd ui && npm run build)..."
(cd ui && npm run build) || { echo "ERROR: UI build failed. Fix TypeScript errors before pushing."; exit 1; }

# ── 5. UI tests ─────────────────────────────────────────────────────────────
echo "[5/5] UI tests (bun test)..."
(cd ui && bun test) || { echo "ERROR: UI tests failed. Fix before pushing."; exit 1; }

echo ""
echo "All pre-push checks passed."
echo ""
