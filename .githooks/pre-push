#!/usr/bin/env bash
# meridian — normalises screenpipe activity into structured app sessions
set -euo pipefail

export SQLX_OFFLINE=true
REPO_ROOT="$(git rev-parse --show-toplevel)"
FAIL=0

run_check() {
  local label="$1"; shift
  local log; log=$(mktemp)
  if "$@" >"$log" 2>&1; then
    echo "  ✓ $label"
  else
    echo "  ✗ $label"
    cat "$log"
    FAIL=1
  fi
  rm -f "$log"
}

echo ""
echo "=== pre-push checks ==="
echo ""

# ── Wave 1: fmt + UI build (fully independent, run in parallel) ─────────────
echo "[wave 1/3] cargo fmt --check  +  ui build"

run_check "cargo fmt --check" cargo fmt --check &
W1_FMT=$!

run_check "ui build" bash -c "cd '$REPO_ROOT/ui' && npm run build" &
W1_UI=$!

wait $W1_FMT
wait $W1_UI

if [[ $FAIL -ne 0 ]]; then
  echo ""
  echo "Wave 1 failed — fix fmt/UI build errors before pushing."
  exit 1
fi

# ── Wave 2: clippy + UI tests (independent of each other, start together) ───
echo ""
echo "[wave 2/3] cargo clippy  +  ui tests"

run_check "cargo clippy" cargo clippy -- -D warnings &
W2_CLIPPY=$!

run_check "ui tests" bash -c "cd '$REPO_ROOT/ui' && bun test" &
W2_UI=$!

wait $W2_CLIPPY
wait $W2_UI

if [[ $FAIL -ne 0 ]]; then
  echo ""
  echo "Wave 2 failed — fix clippy/UI test errors before pushing."
  exit 1
fi

# ── Wave 3: cargo test (sequential after clippy — reuses build artifacts) ───
echo ""
echo "[wave 3/3] cargo test"

run_check "cargo test" cargo test

if [[ $FAIL -ne 0 ]]; then
  echo ""
  echo "Rust tests failed — fix before pushing."
  exit 1
fi

echo ""
echo "All pre-push checks passed."
echo ""
