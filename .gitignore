# Generated by Cargo
debug
/target
meridian.db
meridian.db-shm
meridian.db-wal
.env
.env.local
.env.*.local

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Cargo local config — ignore cache but track config.toml
.cargo/*
!.cargo/config.toml

# AI tooling metadata
.claude-flow/
.agents/*
claude-flow.config.json
data/memory/
# Claude Code
.claude/worktrees/
.claude/*.local* # local changes are specific to the individual developer, let's not check them in for everyone.
.claude/*.lock
.claude/memory.db
.claude/settings.json

# Python virtual environments (.venv313 merged into .venv via --mlx extra)
services/.venv/

# Hermes dev-mode local source checkout (HERMES_DEV_MODE=1)
services/.hermes/
ruvector.db
.mcp.json

# Compiled Swift binaries (sources committed; binaries are platform-specific)
swift/ax_terminal
swift/vscode-panel-reader

# deepeval CLI cache (auto-written by `deepeval test run` / `deepeval login`)
.deepeval/
.deepeval-cache.json
.deepeval_telemetry.txt
.latest_test_run.json
.latest_run_full.json

# Generated eval artifacts — regenerate on demand via render_seeds.py or build_dataset.py
services/tests/evals/data/generated/
services/tests/evals/.dataset.json
services/tests/evals/.synthetic-dataset-*.json

# Eval run results — one JSON per eval_classifier.py invocation, source of truth
# for the eval-feedback skill. Regenerated on every run; never commit.
services/tests/evals/results/

# Python bytecode
__pycache__/
*.pyc

# Autonomous eval-loop runtime state — restartable, regenerated. Decision log
# is informational only.
services/tests/evals/.loop_state.json
services/tests/evals/.loop_queue.json
services/tests/evals/.loop_decisions.md
services/tests/evals/.loop_procedure.md
# In-progress experimental skill revisions written by the autonomous loop.
# Versioned manually when promoted; never auto-committed.
services/skills/activity/task-classifier/skill_v[0-9]*.md
!services/skills/activity/task-classifier/skill_v1.md
dist/

# root release-tooling deps
/node_modules/
